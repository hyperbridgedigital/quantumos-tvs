# ═══ CHARMINAR MEHFIL v1.2.0 ═══
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon (Serverless PostgreSQL)
# Get from: https://console.neon.tech → Project → Connection Details
# Use pooled connection for serverless (host ends with -pooler)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Kynetra AI (REQUIRED for Admin)
KYNETRA_API_KEY=your_kynetra_api_key
KYNETRA_ENDPOINT=https://api.kynetra.hyperbridge.digital
KYNETRA_MODEL=kynetra-cognitive-v2

# Email OTP Provider
RESEND_API_KEY=your_resend_key

# SMS OTP Provider (Fast2SMS)
FAST2SMS_API_KEY=your_fast2sms_key

# WhatsApp (Meta Cloud API)
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_VERIFY_TOKEN=cm_verify_2026

# Meta / Ads
META_APP_ID=
META_PIXEL_ID=

# Payments (Razorpay)
RZP_KEY_ID=
RZP_KEY_SECRET=

# SMS (MSG91 fallback)
MSG91_AUTH_KEY=

# Maps & Analytics
GOOGLE_MAPS_KEY=
GA4_ID=
SENTRY_DSN=
